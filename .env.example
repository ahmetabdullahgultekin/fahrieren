# fahrieren.com — environment variables (Vite, build-time, all VITE_*)
#
# Copy to `.env` and fill in real values. `.env` is git-ignored; this example is
# tracked so the required vars are documented. None of these are secrets — Vite
# inlines VITE_* into the public client bundle, and the Firebase web config is
# public by design. Never put a private key here.

# --- Site / SEO metadata ---
VITE_SITE_TITLE=Fahri Eren - Kaliteli Emlak, Araç ve Tarım Ürünleri | Türkiye
VITE_SITE_DESCRIPTION=Türkiye'nin güvenilir ticaret platformu.
VITE_SITE_KEYWORDS=emlak, araç, tarım ürünleri, inşaat malzemeleri, ticaret, Türkiye
VITE_SITE_AUTHOR=Fahri Eren
VITE_SITE_NAME=Fahri Eren Ticaret
VITE_SITE_URL=https://fahrieren.com

# --- Owner / contact ---
VITE_OWNER_NAME=Fahri Eren
VITE_OWNER_JOB_TITLE=Güvenilir Ticaret Uzmanı
VITE_OWNER_PHONE=+90 5XX XXX XX XX
VITE_OWNER_EMAIL=owner@example.com
VITE_OWNER_CITY=Niğde
VITE_OWNER_LINKEDIN=https://linkedin.com/in/fahrieren
VITE_OWNER_INSTAGRAM=https://instagram.com/fahrieren

# --- Monetization / analytics ---
VITE_GOOGLE_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Reliable lead pipeline (feature flag) ---
# false (default) = legacy submit path, byte-identical to before this feature.
# true            = durable outbox + retry/backoff + idempotent Firestore write,
#                   plus the consent checkbox and the recovery banner.
# Reversible kill-switch: flip back to false and rebuild to disable. Firestore
# App Check enforcement and Cloud Functions are separate OPERATOR steps (see
# docs/design/lead-pipeline.md) and are not required for the durable client path.
VITE_LEAD_PIPELINE_ENABLED=false
