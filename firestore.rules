rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------------------
    // An admin is a signed-in user whose UID has a document in /admins.
    // NOTE: AuthService.isAdmin() reads admins/{user.uid} (doc id == uid),
    // so admin documents MUST be keyed by the user's UID. Seed them from the
    // Firebase Console or the Admin SDK (writes to /admins are denied below).
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Shape validation for lead-capture writes (reliable lead pipeline).
    // Even if App Check is bypassed, these reject malformed / oversized / extra
    // fields, cap message size, require KVKK/GDPR consent, and force server time.
    function isValidContactLead(data) {
      return data.keys().hasOnly([
          'name','email','phone','subject','message',
          'category','source','language','consentAt',
          'createdAt','status','clientLeadId','userAgent'
        ])
        && data.name is string && data.name.size() >= 1 && data.name.size() <= 200
        && data.email is string && data.email.size() >= 5 && data.email.size() <= 254
        && (!('phone' in data) || data.phone == null || (data.phone is string && data.phone.size() <= 20))
        && data.subject is string && data.subject.size() >= 1 && data.subject.size() <= 200
        && data.message is string && data.message.size() >= 1 && data.message.size() <= 2000
        && data.category in ['realestate','vehicles','construction','farm','general']
        && data.source in ['contact_form','product_detail']
        && data.language in ['tr','en']
        && data.consentAt is string && data.consentAt.size() > 0
        && data.createdAt == request.time
        && data.status == 'new'
        && data.clientLeadId is string && data.clientLeadId.size() > 0
        && (!('userAgent' in data) || data.userAgent == null || (data.userAgent is string && data.userAgent.size() <= 500));
    }

    function isValidNewsletterLead(data) {
      return data.keys().hasOnly([
          'email','language','consentAt','createdAt','status','clientLeadId','userAgent'
        ])
        && data.email is string && data.email.size() >= 5 && data.email.size() <= 254
        && data.language in ['tr','en']
        && data.consentAt is string && data.consentAt.size() > 0
        && data.createdAt == request.time
        && data.status == 'active'
        && data.clientLeadId is string && data.clientLeadId.size() > 0
        && (!('userAgent' in data) || data.userAgent == null || (data.userAgent is string && data.userAgent.size() <= 500));
    }

    // ---------------------------------------------------------------------
    // admins — source of truth for admin authorization.
    // Readable only by signed-in users (the app checks its own UID doc).
    // Writes are DENIED from clients: seed/manage admins via Console/Admin SDK
    // only, otherwise anyone could grant themselves admin.
    // ---------------------------------------------------------------------
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ---------------------------------------------------------------------
    // Public catalog content — world-readable, admin-only writes.
    // ---------------------------------------------------------------------
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------------
    // Lead-capture / append-only collections.
    // Anyone may create a record (contact form, newsletter sign-up), but
    // nobody may read, update, or delete from the client. Admins read these
    // via the Console / Admin SDK (which bypass rules).
    // ---------------------------------------------------------------------
    match /contacts/{contactId} {
      // Append-only, shape-validated. Admins read/triage/export.
      allow create: if isValidContactLead(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /newsletter/{subscriberId} {
      allow create: if isValidNewsletterLead(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    // ---------------------------------------------------------------------
    // Analytics telemetry — anonymous visitors increment counters via
    // setDoc(..., {merge:true}) + increment(), so create AND update must be
    // public. Reads (admin dashboard) and deletes are admin-only; the client
    // already degrades gracefully to localStorage on permission-denied.
    // ---------------------------------------------------------------------
    match /analytics/{docId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    match /events/{eventId} {
      // Custom events are addDoc()-created and never updated client-side.
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ---------------------------------------------------------------------
    // Default deny — anything not matched above is forbidden.
    // ---------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
